
# ## Local environment template
# ## Use .env.local for your actual personal secrets.

# # Local database default for Supabase Docker
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Supabase Local Defaults - need these to prevent runtime errors when environment variables are missing
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_LOCAL_ANON_KEY_HERE"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY_HERE"

