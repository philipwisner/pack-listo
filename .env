
# ## Local environment template
# ## Use .env.local for your actual personal secrets.

# # Local database default for Supabase Docker
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Supabase Local Defaults - need these to prevent runtime errors when environment variables are missing
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_LOCAL_ANON_KEY_HERE"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY_HERE"

# For deployed version you need to provide DATABASE_URL and DIRECT_URL to vercel environment variables. You can find these in your Supabase project settings under Database > Connection Pooling. Use the transaction pooler URL for DATABASE_URL and the direct connection URL for DIRECT_URL. This ensures that your application uses the appropriate connection method for regular queries and schema migrations, respectively.

# # Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
# DATABASE_URL="postgresql://postgres.[project-id]:[PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres"

# # Connect to Postgres via the shared session-mode pooler (used for migrations)
# DIRECT_URL="postgresql://postgres.[project-id]:[password]@aws-1-us-west-2.pooler.supabase.com:5432/postgres"

# The rest of the necessary environment variables for vercel are pulled over using the supabase integration