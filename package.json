{
  "name": "pack-listo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && panda codegen && next build",
    "vercel-build": "prisma generate && prisma migrate deploy && panda codegen && next build",
    "start": "next start",
    "lint": "eslint",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "reset-password": "tsx scripts/reset-password.ts",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "db:sync": "prisma format && prisma db push && prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
